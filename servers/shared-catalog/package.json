{
  "name": "shared-catalog-mcp-server",
  "version": "0.2.0",
  "description": "Local MCP server for sharing skills, tool definitions, prompts, and resources across coding tools.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "shared-catalog-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "catalog",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepack": "npm run build",
    "release:check": "npm run typecheck && npm test && npm pack --dry-run --cache ./.npm-cache",
    "release:pack": "npm pack --cache ./.npm-cache"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.2",
    "yaml": "^2.8.0",
    "zod-to-json-schema": "^3.24.6",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
