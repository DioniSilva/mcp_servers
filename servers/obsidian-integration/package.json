{
  "name": "obsidian-integration-mcp-server",
  "version": "0.1.0",
  "description": "Operational MCP server for integrating AI coding agents with Obsidian vaults.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "obsidian-integration-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "resources",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepack": "npm run build",
    "release:check": "npm run typecheck && npm test && npm pack --dry-run --cache ./.npm-cache",
    "release:pack": "npm pack --cache ./.npm-cache"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.2",
    "zod": "^3.25.67",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
