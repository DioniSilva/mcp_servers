{
  "name": "mcp-servers",
  "version": "0.1.0",
  "private": true,
  "description": "Workspace for reusable local MCP servers.",
  "workspaces": [
    "servers/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
